#!/usr/bin/env bash
# Preflight: verifica que el build pase antes de permitir el push.
# Si el build falla, el push se bloquea. No usar --no-verify para saltárselo.
set -e
cd "$(git rev-parse --show-toplevel)"
echo "→ preflight: npm run build…"
npm run build
echo "✓ preflight OK — build verde, push permitido"
